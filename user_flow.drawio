        </mxCell>
        <mxCell id="nLocal" value="Test locally (optional):&lt;br&gt;&lt;font face=&quot;Courier New&quot;&gt;sandbox validate&lt;br&gt;sandbox job run my_job --dry-run&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="360" y="260" width="240" height="80" as="geometry" />
        </mxCell>
