        </mxCell>
        <mxCell id="nRunner" value="Runner executes main()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="380" y="1010" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="nWritten" value="Tables written to S3 + Glue&lt;br&gt;Run logged to &lt;font face=&quot;Courier New&quot;&gt;sandbox_job_runs&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
