# Copy this file to .env and fill in the values.
# The sandbox CLI loads it automatically — no shell setup needed.

# --- Required ---

# S3 bucket name (bucket name only, no s3:// prefix)
SANDBOX_BUCKET=your-sandbox-bucket

# Glue database name
SANDBOX_DATABASE=sandbox_db

# --- Recommended ---

# S3 path where Athena writes query results
SANDBOX_ATHENA_OUTPUT=s3://your-sandbox-bucket/athena-output/

# --- Optional ---

# true = jobs run without writing any data (safe for testing)
SANDBOX_DRY_RUN=true
