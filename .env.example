# Sandbox job framework — environment configuration.
# Copy this file to .env and fill in real values. Note: the framework reads
# plain environment variables and does NOT auto-load .env files — load it
# into your shell first, e.g. in PowerShell:
#   Get-Content .env | Where-Object { $_ -match '^\s*[^#]' } | ForEach-Object {
#     $name, $value = $_ -split '=', 2; Set-Item "env:$name" $value
#   }
# or in bash:  set -a; source .env; set +a

# --- Required ---

# S3 bucket name for sandbox tables (bucket name only, no s3:// prefix)
SANDBOX_BUCKET=your-sandbox-bucket

# Glue database name for sandbox tables
SANDBOX_DATABASE=sandbox_db

# --- Recommended ---

# S3 path where Athena writes query results
SANDBOX_ATHENA_OUTPUT=s3://your-sandbox-bucket/athena-output/

# --- Optional ---

# Athena workgroup (account default is used if unset)
# SANDBOX_WORKGROUP=

# Override the logical run date (YYYY-MM-DD); defaults to today (UTC)
# SANDBOX_RUN_DATE=

# Keep true for your first test run: job code executes but no tables are
# written and no state is updated. Set to false (or remove) for real runs.
SANDBOX_DRY_RUN=true

# --- AWS credentials ---
# Prefer your standard AWS setup (SSO, ~/.aws/credentials, or AWS_PROFILE).
# Only set static keys here as a last resort — never commit real values.
# AWS_PROFILE=
# AWS_DEFAULT_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
